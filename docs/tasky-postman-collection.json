            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/api/projects/{{projectId}}/stats", "host": ["{{base_url}}"], "path": ["api","projects","{{projectId}}","stats"] }
